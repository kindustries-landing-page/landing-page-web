{
  "name": "klotus-landing-page-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vite build && bunx esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "bunx vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "bunx eslint .",
    "format": "bunx prettier --write .",
    "test": "bunx vitest run",
    "prepare": "command -v husky >/dev/null 2>&1 && husky || true",
    "lint:check": "bunx eslint \"src/**/*.{ts,tsx,js,jsx}\" --max-warnings=0",
    "type:check": "bunx tsc --noEmit",
    "check:ci": "bunx tsc --noEmit && bunx eslint \"src/**/*.{ts,tsx,js,jsx}\" --max-warnings=0 && bunx prettier --check ."
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.100.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "i18next": "^26.3.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.8",
    "react-router": "^7.15.1",
    "shadcn": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7",
    "@types/bun": "latest"
  },
  "packageManager": "bun@1.3.5"
}
